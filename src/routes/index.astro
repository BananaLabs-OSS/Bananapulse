---
// bananapulse/routes/index.astro — the status overview page.
//
// Injected by the integration at `${mountPath}` (default /status).
// Pure-static: this Astro file is statically rendered at build time. The
// first paint is a "loading" skeleton; a client <script> then fetches
// the configured upstream every 30s from the browser and patches the DOM.
//
// No server-side fetch happens here. No SSR. No locals.runtime.env.
// Works on any static host (CF Pages, GH Pages, Netlify, S3, nginx).

import config from 'virtual:bananapulse/config';
import baseCss from '../styles/base.css?url';
import defaultThemeCss from '../styles/default-theme.css?url';
import OverallBanner from '../components/OverallBanner.astro';
// AlertBanner and StatusNode are rendered client-side by the inline script,
// not imported here. The script ships its own minimal HTML templates so
// the renderer is self-contained at runtime and the components stay
// reusable for SSR contexts (e.g. the build-time "active incidents" block,
// which uses IncidentCard below).
import IncidentCard from '../components/IncidentCard.astro';
import { loadIncidents } from '../lib/incidents.js';

// Build-time read for the "active incidents" block. The status tree
// itself is hydrated client-side. Absolute path is baked in by the
// integration's config:setup hook — see src/integration.ts.
const active = loadIncidents(config.absIncidentsPath).filter(
  (i) => !i.resolvedAt,
);

const mount = config.mountPath;
const feedHref = mount === '/' ? '/incidents.xml' : `${mount}/incidents.xml`;
const historyHref = mount === '/' ? '/incidents' : `${mount}/incidents`;
// Theme resolution: if themeCssPath was set + file was readable, the
// integration baked its contents into config.themeCss. We render that
// inline and skip default-theme.css. Otherwise default-theme.css loads.
const useDefaultTheme = !config.themeCssPath || !config.themeCss;
const inlineThemeCss: string = config.themeCss ?? '';

// Build the theme-remap CSS block. If the consumer mapped Bananapulse's
// vars to their own, emit `:root { --accent: var(--brand-blue); ... }`
// so Bananapulse's components naturally pick up the consumer's tokens.
const themeRemap = Object.entries(config.themeCssVarMap ?? {})
  .map(([from, to]) => `  ${from}: var(${to});`)
  .join('\n');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{config.name} status</title>
    <meta
      name="description"
      content={`${config.name} live system status, incidents, and capacity.`}
    />
    <link rel="alternate" type="application/atom+xml"
          title={`${config.name} incidents`} href={feedHref} />
    <link rel="stylesheet" href={baseCss} />
    {useDefaultTheme && <link rel="stylesheet" href={defaultThemeCss} />}
    {inlineThemeCss && <style set:html={inlineThemeCss}></style>}
    {themeRemap && (
      <style set:html={`:root {\n${themeRemap}\n}`}></style>
    )}
  </head>
  <body>
    <main>
      <div class="kit-header">
        <div>
          <a href={mount} style="color: inherit"><strong>{config.name}</strong> status</a>
        </div>
        <a class="domain" href={`https://${config.domain}`}>{config.domain}</a>
      </div>

      <div id="bp-overall">
        <OverallBanner overall="operational" siteName={config.name} />
      </div>
      <div id="bp-banner"></div>

      {active.length > 0 && (
        <>
          <h2>Active incidents</h2>
          <div>
            {active.map((i) => <IncidentCard incident={i} />)}
          </div>
        </>
      )}

      {/*
        Canonical-source incidents are injected client-side by the
        poller into #bp-incidents / #bp-maintenance. The build-time
        block above (driven by incidents.json) stays as the fallback
        for non-canonical sources — the poller never touches it.
      */}
      <div id="bp-incidents"></div>
      <div id="bp-maintenance"></div>

      <h2>Systems</h2>
      <section class="tree" id="bp-tree">
        <p class="updated">Loading status…</p>
      </section>

      <p class="updated">
        Updated <time datetime="" id="bp-updated">—</time>
        · <a href={historyHref}>incident history</a>
        · <a href={feedHref}>Atom feed</a>
      </p>
    </main>
    <footer class="kit-foot">
      Powered by <a href="https://github.com/BananaLabs-OSS/bananapulse">Bananapulse</a>
    </footer>

    <script type="module" define:vars={{ sources: config.sources, siteName: config.name }}>
      // Client-side poller. Fetches the consumer's upstream directly
      // from the browser every 30s. CORS on the upstream is the
      // consumer's responsibility (see DEPLOY.md).
      const POLL_MS = 30_000;

      const LABEL = {
        operational: 'Operational',
        degraded: 'Degraded',
        major: 'Major outage',
        maintenance: 'Maintenance',
      };
      const HEADLINE = {
        operational: 'All systems operational',
        degraded: 'Some systems are experiencing issues',
        major: 'Major outage in progress',
        maintenance: 'Scheduled maintenance underway',
      };

      function mapDependencyHealth(raw) {
        if (raw === 'reachable' || raw === 'ok' || raw === 'healthy') return 'operational';
        if (raw === 'degraded' || raw === 'slow') return 'degraded';
        if (raw === 'unreachable' || raw === 'down' || raw === 'error') return 'major';
        return 'degraded';
      }
      function mapCapacityHealth(used, full) {
        if (full) return 'degraded';
        if (used >= 90) return 'degraded';
        return 'operational';
      }
      const RANK = { maintenance: 0, operational: 1, degraded: 2, major: 3 };
      function worse(a, b) { return RANK[a] >= RANK[b] ? a : b; }
      function rollup(subs) {
        let h = 'maintenance';
        for (const s of subs) h = worse(h, s.status);
        if (h === 'maintenance' && subs.some((s) => s.status !== 'maintenance')) return 'operational';
        return h;
      }

      function mapQueueStatus(raw) {
        // Resource %s are telemetry, not status. The status page answers
        // "is it up?" — meters intentionally omitted. Capacity status
        // rolls up CPU/RAM thresholds + capacity_full flag internally.
        const cap = mapCapacityHealth(Math.max(raw.used_cpu, raw.used_memory), raw.capacity_full);
        const subsystems = [
          {
            name: 'Server capacity',
            status: cap,
            message: raw.capacity_full
              ? `Capacity full — ${raw.queue_length} in queue`
              : `${raw.active_servers}/${raw.max_servers} units active`,
          },
          { name: 'Provisioner', status: mapDependencyHealth(raw.provisioner_status) },
          { name: 'Payments', status: mapDependencyHealth(raw.payments_status) },
          { name: 'Email delivery', status: mapDependencyHealth(raw.email_status) },
        ];
        const overall = rollup(subsystems);
        const banner = raw.capacity_full && raw.estimated_next_slot
          ? { tone: 'degraded', text: `Capacity full — next slot estimated ${new Date(raw.estimated_next_slot).toUTCString()}` }
          : null;
        return { overall, subsystems, updatedAt: new Date().toISOString(), banner };
      }

      // Pre-canonicalized API response: upstream already returns the
      // canonical shape, we just translate `components` (API) → `subsystems`
      // (renderer), null-coerce message, and derive a banner from the
      // highest-severity active incident. Trust-but-shape: the upstream
      // is our own backend, so we don't validate every field — but a
      // missing/wrong-typed overall trips `unreachable()` upstream of here.
      function componentToSubsystem(c) {
        return {
          id: c.id,        // carried through for incident-affects id→name lookup
          slug: c.slug,    // carried through for future selector use
          name: c.name,
          status: c.status,
          message: c.message == null ? undefined : c.message,
          children: Array.isArray(c.children) ? c.children.map(componentToSubsystem) : undefined,
        };
      }
      const SEV_RANK = { operational: 0, maintenance: 1, degraded: 2, major: 3 };
      function deriveBanner(overall, activeIncidents, activeMaintenance) {
        const all = [...activeIncidents, ...activeMaintenance];
        if (all.length > 0) {
          let top = all[0];
          for (const i of all) if (SEV_RANK[i.severity] > SEV_RANK[top.severity]) top = i;
          const prefix = top.severity === 'maintenance' ? 'In progress' : 'Investigating';
          return { tone: top.severity, text: `${prefix}: ${top.title}` };
        }
        if (overall === 'maintenance') return { tone: 'maintenance', text: 'Scheduled maintenance underway.' };
        return null;
      }
      function mapCanonical(raw) {
        if (!raw || !LABEL[raw.overall] || !Array.isArray(raw.components)) {
          throw new Error('canonical: shape invalid');
        }
        const subsystems = raw.components.map(componentToSubsystem);
        const incidents = Array.isArray(raw.incidents) ? raw.incidents : [];
        const maintenance = Array.isArray(raw.maintenance) ? raw.maintenance : [];
        const activeI = incidents.filter((i) => !i.resolvedAt);
        const activeM = maintenance.filter((i) => !i.resolvedAt);
        const banner = deriveBanner(raw.overall, activeI, activeM);
        return {
          status: {
            overall: raw.overall,
            subsystems,
            updatedAt: raw.updatedAt || new Date().toISOString(),
            banner,
          },
          incidents,
          maintenance,
        };
      }

      function unreachable() {
        return {
          overall: 'major',
          subsystems: [{ name: siteName, status: 'major', message: 'Upstream status endpoint unreachable' }],
          updatedAt: new Date().toISOString(),
          banner: { tone: 'major', text: 'Status data unavailable. Check back in 30 seconds.' },
        };
      }
      function unreachableResult() {
        return { status: unreachable(), incidents: [], maintenance: [] };
      }

      async function fetchStatus() {
        const src = sources && sources[0];
        if (!src) return unreachableResult();
        try {
          const r = await fetch(src.url, { headers: { Accept: 'application/json' } });
          if (!r.ok) return unreachableResult();
          const raw = await r.json();
          if (src.type === 'queue-status') {
            return { status: mapQueueStatus(raw), incidents: [], maintenance: [] };
          }
          if (src.type === 'canonical') {
            try { return mapCanonical(raw); }
            catch { return unreachableResult(); }
          }
          return unreachableResult();
        } catch {
          return unreachableResult();
        }
      }

      function escapeHtml(s) {
        return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      }
      function meterHtml(m) {
        if (!m) return '';
        const pct = Math.max(0, Math.min(100, (m.value / Math.max(m.max, 1)) * 100));
        const tone = pct >= 90 ? 'degraded' : 'operational';
        return `<div class="meter"><div class="meter-row"><span class="meter-label">${escapeHtml(m.label)}</span><span class="meter-val">${Math.round(m.value)}%</span></div><div class="meter-bar"><div class="meter-fill tone-${tone}" style="width:${pct}%"></div></div></div>`;
      }
      function rowHtml(s) {
        const msg = s.message ? `<p class="row-msg">${escapeHtml(s.message)}</p>` : '';
        return `<div class="row tone-${s.status}"><div class="row-main"><div class="row-head"><span class="dot ${s.status}"></span><span class="row-name">${escapeHtml(s.name)}</span></div><span class="row-status tone-${s.status}">${LABEL[s.status]}</span></div>${msg}${meterHtml(s.meter)}</div>`;
      }
      function overallHtml(overall, name) {
        return `<section class="overall tone-${overall}"><div class="overall-row"><span class="dot ${overall}"></span><h1>${HEADLINE[overall]}</h1></div><p class="overall-sub">${escapeHtml(name)} status</p></section>`;
      }
      function bannerHtml(b) {
        if (!b) return '';
        return `<aside class="alert tone-${b.tone}"><span class="dot ${b.tone}"></span><span>${escapeHtml(b.text)}</span></aside>`;
      }

      // Mirrors IncidentCard.astro's structure + .incident class so the
      // theme CSS picks these up automatically. Resolved timestamps are
      // omitted by the active-only filter in render() — only the
      // ongoing/resolved meta text differs for those that slip through.
      const INC_LABEL = {
        degraded: 'Degraded',
        major: 'Major outage',
        maintenance: 'Maintenance',
      };
      // buildComponentMap walks the components tree (recursive) and
      // returns slug → {name, slug, id} so incident-affects can render
      // names instead of bare slugs. (Pre-M8 this was keyed by integer
      // id; the canonical wire now ships slug strings in
      // `affectedComponents`, which are stable across schema renumbers.)
      function buildComponentMap(nodes) {
        const map = new Map();
        function walk(xs) {
          for (const c of xs) {
            if (c.slug) map.set(c.slug, c);
            if (Array.isArray(c.children)) walk(c.children);
          }
        }
        walk(nodes || []);
        return map;
      }

      function incidentHtml(i, componentMap) {
        const sev = INC_LABEL[i.severity] ? i.severity : 'degraded';
        const started = i.startedAt ? new Date(i.startedAt).toUTCString() : '';
        const resolved = i.resolvedAt ? new Date(i.resolvedAt).toUTCString() : '';
        const startedHtml = started
          ? `Started <time datetime="${escapeHtml(i.startedAt)}">${escapeHtml(started)}</time>`
          : '';
        const stateHtml = resolved
          ? ` · resolved <time datetime="${escapeHtml(i.resolvedAt)}">${escapeHtml(resolved)}</time>`
          : ' <span class="ongoing"> · ongoing</span>';
        // Body comes through as upstream HTML (canonical contract says
        // `body: '<p>...</p>'`). The Sessions Worker is the trust boundary
        // here — Evolution's renderer is the only producer.
        const bodyHtml = typeof i.body === 'string' ? i.body : '';
        const idAttr = typeof i.id === 'string' && i.id ? ` id="${escapeHtml(i.id)}"` : '';
        // Updates render as a reverse-chronological timeline below the
        // body. Each update is `{ body: '<p>html</p>', postedAt: ISO }`.
        // The `reversed` attr on `<ol>` makes the visible numbering match
        // the newest-first order without us inverting the actual items.
        const updates = Array.isArray(i.updates) ? i.updates : [];
        const updatesHtml = updates.length > 0
          ? `<ol class="incident-updates" reversed>`
            + updates.slice().reverse().map(u => {
                const posted = u.postedAt ? new Date(u.postedAt).toUTCString() : '';
                const ts = posted
                  ? `<time class="incident-update-time" datetime="${escapeHtml(u.postedAt)}">${escapeHtml(posted)}</time>`
                  : '';
                const ubody = typeof u.body === 'string' ? u.body : '';
                return `<li class="incident-update">${ts}<div class="incident-update-body">${ubody}</div></li>`;
              }).join('')
            + `</ol>`
          : '';
        // Optional postmortem link rendered after the timeline.
        const postmortemHtml = typeof i.postmortemUrl === 'string' && i.postmortemUrl
          ? `<a class="incident-link" href="${escapeHtml(i.postmortemUrl)}" target="_blank" rel="noopener">Read postmortem →</a>`
          : '';
        // Affected-components chips: looked up by slug from the
        // components map so customers see "Affects: Checkout, Provisioning"
        // not "Affects: checkout, provisioning". Unknown slugs are
        // dropped silently. (M8: wire ships slugs; pre-M8 backends sent
        // integer ids, so accept either while the rollout is in flight.)
        const affects = Array.isArray(i.affectedComponents) ? i.affectedComponents : [];
        const affectsChips = affects
          .map(key => componentMap && componentMap.get(key))
          .filter(Boolean)
          .map(c => `<span class="incident-affect-chip">${escapeHtml(c.name)}</span>`)
          .join('');
        const affectsHtml = affectsChips
          ? `<p class="incident-affects"><span class="incident-affects-label">Affects:</span> ${affectsChips}</p>`
          : '';
        return `<article${idAttr} class="incident tone-${sev}">`
          + `<header class="incident-head">`
          + `<span class="dot ${sev}"></span>`
          + `<h2>${escapeHtml(i.title || '')}</h2>`
          + `<span class="badge tone-${sev}">${INC_LABEL[sev]}</span>`
          + `</header>`
          + `<p class="incident-meta">${startedHtml}${startedHtml ? stateHtml : ''}</p>`
          + affectsHtml
          + `<div class="incident-body">${bodyHtml}</div>`
          + updatesHtml
          + postmortemHtml
          + `</article>`;
      }
      function incidentListHtml(heading, items, componentMap) {
        if (!items || items.length === 0) return '';
        const cards = items.map(i => incidentHtml(i, componentMap)).join('');
        return `<h2>${escapeHtml(heading)}</h2><div>${cards}</div>`;
      }

      function render(result) {
        const status = result.status;
        const overall = document.getElementById('bp-overall');
        const banner = document.getElementById('bp-banner');
        const tree = document.getElementById('bp-tree');
        const updated = document.getElementById('bp-updated');
        const incidentsEl = document.getElementById('bp-incidents');
        const maintenanceEl = document.getElementById('bp-maintenance');
        if (overall) overall.innerHTML = overallHtml(status.overall, siteName);
        if (banner) banner.innerHTML = bannerHtml(status.banner);
        if (tree) tree.innerHTML = status.subsystems.map(rowHtml).join('');
        if (updated && status.updatedAt) {
          updated.setAttribute('datetime', status.updatedAt);
          updated.textContent = new Date(status.updatedAt).toUTCString();
        }
        // Canonical-source incidents: only render the active subset.
        // History stays on /status/incidents (build-time route). For
        // non-canonical sources result.incidents/maintenance are empty
        // and these divs stay untouched after first paint — the
        // build-time block above still shows incidents.json content.
        const activeIncidents = (result.incidents || []).filter((i) => !i.resolvedAt);
        const activeMaintenance = (result.maintenance || []).filter((i) => !i.resolvedAt);
        // Component map built once per render so id→name lookups in
        // incident-affects don't repeat the tree walk for each card.
        const componentMap = buildComponentMap(status.subsystems);
        if (incidentsEl) {
          incidentsEl.innerHTML = incidentListHtml('Active incidents', activeIncidents, componentMap);
        }
        if (maintenanceEl) {
          maintenanceEl.innerHTML = incidentListHtml('Scheduled maintenance', activeMaintenance, componentMap);
        }
      }

      async function poll() {
        const result = await fetchStatus();
        render(result);
      }
      poll();
      setInterval(poll, POLL_MS);
    </script>
  </body>
</html>
