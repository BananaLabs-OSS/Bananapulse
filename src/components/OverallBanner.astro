---
import type { Health } from '../lib/canonical.js';

interface Props {
  overall: Health;
  siteName: string;
}
const { overall, siteName } = Astro.props;

const HEADLINE: Record<Health, string> = {
  operational: 'All systems operational',
  degraded: 'Some systems are experiencing issues',
  major: 'Major outage in progress',
  maintenance: 'Scheduled maintenance underway',
};
---
<section class={`overall tone-${overall}`}>
  <div class="overall-row">
    <span class={`dot ${overall}`}></span>
    <h1>{HEADLINE[overall]}</h1>
  </div>
  <p class="overall-sub">{siteName} status</p>
</section>

<style>
  .overall {
    padding: 24px 24px 28px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    margin-bottom: 32px;
  }
  .overall-row { display: flex; align-items: center; gap: 4px; }
  .overall-sub { margin-top: 4px; font-size: 13px; color: var(--muted); }
  .overall.tone-operational { box-shadow: inset 0 0 0 1px var(--gg); }
  .overall.tone-degraded    { box-shadow: inset 0 0 0 1px var(--yg); }
  .overall.tone-major       { box-shadow: inset 0 0 0 1px var(--rg); }
  .overall.tone-maintenance { box-shadow: inset 0 0 0 1px var(--accent-bg); }
</style>
