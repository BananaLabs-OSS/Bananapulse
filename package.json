{
  "name": "bananapulse",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Astro integration for self-deploy status pages. Pure static, no vendor lock — drop into any Astro site, deploy to any static host.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./routes/index.astro": "./src/routes/index.astro",
    "./routes/incidents.astro": "./src/routes/incidents.astro",
    "./styles/base.css": "./src/styles/base.css",
    "./styles/default-theme.css": "./src/styles/default-theme.css",
    "./components/*": "./src/components/*",
    "./lib/*": "./src/lib/*"
  },
  "files": [
    "src",
    "README.md",
    "DEPLOY.md"
  ],
  "scripts": {
    "dev": "cd dev && astro dev",
    "build": "cd dev && astro build",
    "preview": "cd dev && astro preview",
    "check": "cd dev && astro check"
  },
  "peerDependencies": {
    "astro": "^5.7.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@types/node": "^25.6.0",
    "astro": "^5.7.0",
    "typescript": "^5.9.3"
  }
}
